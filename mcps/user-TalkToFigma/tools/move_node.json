{
  "name": "move_node",
  "description": "Move a node to a new position in Figma",
  "arguments": {
    "type": "object",
    "properties": {
      "nodeId": {
        "type": "string",
        "description": "The ID of the node to move"
      },
      "x": {
        "type": "number",
        "description": "New X position"
      },
      "y": {
        "type": "number",
        "description": "New Y position"
      }
    },
    "required": [
      "nodeId",
      "x",
      "y"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}