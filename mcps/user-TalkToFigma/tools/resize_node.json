{
  "name": "resize_node",
  "description": "Resize a node in Figma",
  "arguments": {
    "type": "object",
    "properties": {
      "nodeId": {
        "type": "string",
        "description": "The ID of the node to resize"
      },
      "width": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "New width"
      },
      "height": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "New height"
      }
    },
    "required": [
      "nodeId",
      "width",
      "height"
    ],
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}